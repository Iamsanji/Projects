{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "bmi-calculator",
  "version": "0.1.0",
  "identifier": "com.josh.bmi-calculator",
  "build": {
    "beforeDevCommand": ".\\node_modules\\.bin\\vite",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": ".\\node_modules\\.bin\\vite",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "BMI Calculator",
        "width": 500,
        "height": 850
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
